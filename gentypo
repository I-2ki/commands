#!/bin/bash
# Usage: ./typo.sh "word" "prob"
# 受け取ったwordをprob%の確率でランダムにtypoさせる
#
if [ -z $1 ]; then
	echo "gentypo: please input word to be typoed"
	exit 1;
fi

word="$1"
prob="${2:-5}"  # デフォルト5%
result=""

lower="abcdefghijklmnopqrstuvwxyz "
upper="ABCDEFGHIJKLMNOPQRSTUVWXYZ "

len=${#word}

for (( i=0; i<len; i++ )); do
    c="${word:$i:1}"

    # 0-99の乱数を生成し、probより小さければtypoさせる
    roll=$(( RANDOM % 100 ))

    if [[ "$c" =~ [a-z] ]] && (( roll < prob )); then
        idx=$(( RANDOM % 27 ))
        result+="${lower:$idx:1}"
    elif [[ "$c" =~ [A-Z] ]] && (( roll < prob )); then
        idx=$(( RANDOM % 27 ))
        result+="${upper:$idx:1}"
    else
        result+="$c"
    fi
done

echo "$result"

